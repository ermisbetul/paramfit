[files]
ref_file = "ref.txt"
output_file = "paramfit_hco_explicit_maemax.out"
parameter_output_file = "paramfit_hco_explicit_maemax.params.toml"

[data]
qcmethod = "SCF"
charge_type = "IAO_MULLIKEN"
# If omitted, paramfit counts ref entries and output files automatically.
# ndata = 115

[model]
solvent_eps = 78.3553
gb_sij = 0.75
gb_dij = 4.0
gb_dch = 4.0
gb_cij = 0.0

[parameters]
fit_atoms = ["H", "C", "O"]
# initial_parameter_file = "previous_stage.params.toml"
parameter_mode = "explicit"
optimize_sij = true
optimize_dij = true
optimize_dch = true

[optimization]
algorithm = "global"
objective = "mae-max"
max_penalty_weight = 1.0
global_maxiter = 80
popsize = 15
seed = 1
polish = true

[tolerances]
mae_tol = 0.50
rms_tol = 0.80
max_tol = 2.50
