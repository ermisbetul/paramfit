$set_molecule
0 1
P       0.0002164135     0.0001229775    -0.1282872697
H      -0.5312246705    -1.0697576611     0.6401062041
H      -0.6626985765     0.9926868208     0.6413239585
H       1.1906770451     0.0752261776     0.6428788824
$end_molecule


$set_globals
   basis cc-pvdz
  method mp2
  reference rhf
  jobtype energy
  memory 30000
$end_globals


$set_scf
  e_convergence 1.0e-8
  d_convergence 1.0e-6
  guess sad
  solvation true
$end_scf


$set_solvation
  cds_type smd
  radius_type smd
  solvent_params mn21
  dielectric_params mn21 #sm8
  sasa_type numeric
  solvent water
  num_ang_points 100
  charge_type iao_mulliken #iao_lowdin, mulliken, lowdin
  coulomb_radii smd
$end_solvation

$set_dfocc
solvation true
$end_dfocc

