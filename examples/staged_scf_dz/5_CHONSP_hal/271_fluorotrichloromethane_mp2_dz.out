$set_molecule
0 1
Cl      0.7951259348    -1.4927548080     0.3102453814
Cl     -1.6909274130     0.0581956353     0.3108170677
Cl      0.8961661840     1.4342572411     0.3106420723
F      -0.0005729582     0.0006103843    -1.5904486745
C      -0.0001738956    -0.0000601035    -0.2541564656
$end_molecule


$set_globals
  basis cc-pvdz
  method mp2
  reference rhf
  jobtype energy
  memory 30000
$end_globals


$set_scf
  e_convergence 1.0e-8
  d_convergence 1.0e-6
