  solvation true
$end_scf


$set_solvation
  cds_type smd
  radius_type smd
  solvent_params mn21
  dielectric_params mn21 #sm8
  sasa_type numeric
  solvent water
  num_ang_points 100
  charge_type iao_mulliken #iao_lowdin, mulliken, lowdin
  coulomb_radii smd
$end_solvation

$set_dfocc
solvation true
$end_dfocc

