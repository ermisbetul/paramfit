H       1.8628934740     0.4918109732     0.9072488013
H       1.8629778147    -1.0316968199    -0.0278251803
$end_molecule


$set_globals
   basis cc-pvdz
  method mp2
  reference rhf
  jobtype energy
  memory 30000
$end_globals


$set_scf
  e_convergence 1.0e-8
  d_convergence 1.0e-6
