$set_molecule
0 1
N      -0.0000046426    -0.0000171016     0.1153966121
H       0.9284278157    -0.1333282938    -0.2692546214
H      -0.3486897974     0.8707036853    -0.2692316794
H      -0.5797055202    -0.7372556803    -0.2692899842
$end_molecule


$set_globals
   basis cc-pvdz
  method mp2
  reference rhf
  jobtype energy
  memory 30000
$end_globals


$set_scf
  e_convergence 1.0e-8
  d_convergence 1.0e-6
  guess sad
  solvation true
$end_scf


$set_solvation
  cds_type smd
  radius_type smd
  solvent_params mn21
  dielectric_params mn21 #sm8
  sasa_type numeric
  solvent water
  num_ang_points 100
  charge_type iao_mulliken #iao_lowdin, mulliken, lowdin
  coulomb_radii smd
$end_solvation

$set_dfocc
solvation true
$end_dfocc

