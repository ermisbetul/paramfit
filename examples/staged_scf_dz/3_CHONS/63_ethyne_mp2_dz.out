  radius_type smd
  solvent_params mn21
  dielectric_params mn21
  sasa_type numeric
  solvent water
  num_ang_points 100
  charge_type iao_mulliken
  coulomb_radii smd
$end_solvation

$set_dfocc
solvation true
$end_dfocc

