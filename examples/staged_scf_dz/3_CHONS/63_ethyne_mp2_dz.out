H       0.0000429568     0.0000000000     1.6596571525
H      -0.0000429568     0.0000000000    -1.6596571525
$end_molecule


$set_globals
   basis cc-pvdz
  method mp2
  reference rhf
  jobtype energy
  memory 30000
$end_globals


